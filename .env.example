# ============================================================
# Rooted Server — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas ---
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/rooted?retryWrites=true&w=majority

# --- Better Auth ---
# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_super_secret_key_min_32_chars
BETTER_AUTH_URL=http://localhost:5000

# --- Google OAuth (Better Auth social login) ---
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Authorized redirect URI to add: http://localhost:5000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Groq AI (Sage chat + recommendations) ---
# Free tier available at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000
